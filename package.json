{
  "name": "dataverse-rcportal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "seed": "node scripts/seed-demo.mjs",
    "seed:related": "node scripts/seed-demo.mjs related",
    "seed:clean": "node scripts/seed-demo.mjs --clean",
    "generate:types": "dataverse-client generate --url https://api.dataverse-contact.tnapps.co.uk --scope rcportal --output src/types/dataverse.generated.ts",
    "types:check": "node scripts/check-types-drift.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.16.0",
    "@azure/msal-react": "^5.5.1",
    "@tanstack/react-query": "^5.101.2",
    "@truenorth-it/dataverse-client": "^1.7.0",
    "dompurify": "^3.4.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
