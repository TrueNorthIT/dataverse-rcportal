{
  "name": "dataverse-rcportal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "seed": "node scripts/seed-demo.mjs",
    "seed:related": "node scripts/seed-demo.mjs related",
    "seed:clean": "node scripts/seed-demo.mjs --clean",
    "generate:types": "dataverse-client generate --url https://api.dataverse-contact.tnapps.co.uk --scope rcportal --output src/types/dataverse.generated.ts",
    "types:check": "node scripts/check-types-drift.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.16.0",
    "@azure/msal-react": "^5.5.1",
    "@tanstack/react-query": "^5.101.2",
    "@truenorth-it/dataverse-client": "^1.5.0",
    "dompurify": "^3.4.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
