# ─── dataverse-rcportal — environment template ──────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.

# Dataverse Contact API — deployment + scope this portal talks to.
# The trailing segment ("rcportal") is the API scope partition.
VITE_API_BASE_URL=https://api.dataverse-contact.tnapps.co.uk/api/v2/rcportal

# ─── SPA sign-in (Microsoft Entra External ID — MSAL PKCE, SPA flow) ─────────
# The Contact API migrated off Auth0 to Entra External ID. Values come from the
# SPA app registration in the CIAM tenant:
#   tenant id  → the ciamlogin.com tenant (also the authority host)
#   client id  → the SPA app registration's Application (client) id
#   api scope  → "api://<api-app-id>/access_as_user"
# The app registration must list http://localhost:5173 as a SPA redirect URI.
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_CLIENT_ID=11111111-1111-1111-1111-111111111111
VITE_ENTRA_API_SCOPE=api://<api-app-id>/access_as_user

# ─── Optional: direct-Dataverse provisioning (scripts only, NOT the SPA) ─────
# A service principal with access to your Dataverse environment. Only needed if
# you add local schema/seed scripts that hit Dataverse directly; the portal
# itself never uses these — it only ever calls the Contact API above.
VITE_TENANT_ID=your-azure-tenant-id
VITE_CLIENT_ID=your-app-registration-client-id
VITE_DATAVERSE_URL=https://your-org.crm11.dynamics.com
CLIENT_SECRET=

# ─── Optional: site location map (MapTiler static maps) ─────────────────────
# When set, the site detail page shows a styled static map of the address.
# Free key from https://cloud.maptiler.com — restrict it to your domain, since
# it ships in the client bundle. Unset simply hides the map (no error).
# Backfill coordinates first with: node scripts/backfill-site-geo.mjs
VITE_MAPTILER_KEY=

# ─── Playwright E2E credentials (an Entra External ID test user) ────────────
ENTRA_TEST_EMAIL=
ENTRA_TEST_PASSWORD=
