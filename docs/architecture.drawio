<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="rcportal-arch" name="Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Redcentric Contact Portal — Architecture" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#142d46;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="700" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="React SPA · containerised API · Microsoft Dataverse — all hosted in UK Azure (UK South)" style="text;html=1;fontSize=13;align=left;verticalAlign=middle;fontColor=#005862;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="760" height="22" as="geometry" />
        </mxCell>

        <!-- Entra External ID (auth) — Microsoft logo -->
        <mxCell id="entra" value="Microsoft Entra External ID&#10;(CIAM — customer sign-in, UK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8f0f1;strokeColor=#005862;fontColor=#00272b;fontSize=13;fontStyle=1;shape=label;image=https://api.iconify.design/logos/microsoft-icon.svg;imageWidth=30;imageHeight=30;imageAlign=center;imageVerticalAlign=top;verticalAlign=top;spacingTop=40;" vertex="1" parent="1">
          <mxGeometry x="450" y="140" width="300" height="100" as="geometry" />
        </mxCell>

        <!-- Azure boundary around the app hosting (SPA + API) -->
        <mxCell id="azure" value="Microsoft Azure — UK South (UK data residency)" style="rounded=1;dashed=1;html=1;verticalAlign=top;align=left;spacingLeft=44;spacingTop=12;fillColor=#f7fbff;strokeColor=#0066b3;fontColor=#0066b3;fontStyle=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="280" y="330" width="640" height="200" as="geometry" />
        </mxCell>
        <mxCell id="azurelogo" style="shape=image;html=1;image=https://api.iconify.design/logos/microsoft-azure.svg;imageAspect=1;" vertex="1" parent="1">
          <mxGeometry x="292" y="338" width="26" height="26" as="geometry" />
        </mxCell>

        <!-- End user -->
        <mxCell id="user" value="Customer&#10;(browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fa;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;shape=label;image=https://api.iconify.design/mdi/account.svg?color=%230066b3;imageWidth=34;imageHeight=34;imageAlign=center;imageVerticalAlign=top;verticalAlign=top;spacingTop=44;" vertex="1" parent="1">
          <mxGeometry x="40" y="372" width="160" height="120" as="geometry" />
        </mxCell>

        <!-- SPA on Azure Static Web Apps — React logo -->
        <mxCell id="spa" value="Contact Portal (SPA)&#10;React&#10;Azure Static Web Apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9e8f4;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;fontStyle=1;shape=label;image=https://api.iconify.design/logos/react.svg;imageWidth=40;imageHeight=40;imageAlign=center;imageVerticalAlign=top;verticalAlign=top;spacingTop=50;" vertex="1" parent="1">
          <mxGeometry x="320" y="362" width="230" height="146" as="geometry" />
        </mxCell>

        <!-- Contact API on Azure via Docker — Docker logo -->
        <mxCell id="api" value="Contact Portal API&#10;Docker container&#10;Azure Container Apps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9e8f4;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;fontStyle=1;shape=label;image=https://api.iconify.design/logos/docker-icon.svg;imageWidth=44;imageHeight=44;imageAlign=center;imageVerticalAlign=top;verticalAlign=top;spacingTop=52;" vertex="1" parent="1">
          <mxGeometry x="650" y="362" width="230" height="146" as="geometry" />
        </mxCell>

        <!-- Dataverse — Microsoft logo -->
        <mxCell id="dv" value="Microsoft Dataverse&#10;Power Platform (UK)&#10;&#10;accounts · contacts · quotes&#10;projects · cases · sites" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#efe6fb;strokeColor=#6a2fb5;fontColor=#2d1155;fontSize=12;fontStyle=1;shape=label;image=https://api.iconify.design/logos/microsoft-icon.svg;imageWidth=30;imageHeight=30;imageAlign=center;imageVerticalAlign=top;verticalAlign=top;spacingTop=42;" vertex="1" parent="1">
          <mxGeometry x="1020" y="360" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e_user_spa" value="loads portal (HTTPS)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#142d46;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="user" target="spa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_spa_entra" value="sign in (OIDC / PKCE)&#10;→ access token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#005862;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="spa" target="entra">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_entra" value="validate JWT (JWKS)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#005862;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="api" target="entra">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_spa_api" value="REST + Bearer token&#10;(X-Contact-Id)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#0066b3;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="spa" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_dv" value="Dataverse Web API&#10;(service principal)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#6a2fb5;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="api" target="dv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="Users sign in with Entra External ID; the SPA sends the access token to the API, which validates it and resolves the caller's Dataverse contact + permissions server-side. The SPA never calls Dataverse directly — only the API does, via an Entra service principal (client credentials)." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=12;fontColor=#005862;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1230" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
