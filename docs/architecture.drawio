<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="rcportal-arch" name="Architecture">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Redcentric Contact Portal — Architecture" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;fontColor=#142d46;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="520" height="30" as="geometry" />
        </mxCell>

        <!-- End user -->
        <mxCell id="user" value="Customer&#10;(browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fa;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- Entra External ID (auth) -->
        <mxCell id="entra" value="Microsoft Entra External ID&#10;(CIAM — customer sign-in)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d8f0f1;strokeColor=#005862;fontColor=#00272b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="90" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Azure boundary -->
        <mxCell id="azure" value="Microsoft Azure — UK South (UK data residency)" style="rounded=1;dashed=1;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fillColor=none;strokeColor=#0066b3;fontColor=#0066b3;fontStyle=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="230" y="270" width="560" height="150" as="geometry" />
        </mxCell>

        <!-- SPA on Azure Static Web Apps -->
        <mxCell id="spa" value="Contact Portal (SPA)&#10;React&#10;Azure Static Web Apps (UK South)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9e8f4;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Contact API on Azure via Docker -->
        <mxCell id="api" value="Contact Portal API&#10;Docker container&#10;Azure Container Apps (UK South)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9e8f4;strokeColor=#0066b3;fontColor=#142d46;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Dataverse -->
        <mxCell id="dv" value="Microsoft Dataverse&#10;Power Platform (UK region)&#10;accounts · contacts · opportunities&#10;quotes · projects · cases" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#efe6fb;strokeColor=#6a2fb5;fontColor=#2d1155;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="295" width="230" height="100" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e_user_spa" value="loads portal (HTTPS)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#142d46;" edge="1" parent="1" source="user" target="spa">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_spa_entra" value="sign in (OIDC / PKCE)&#10;→ ID + access token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;startArrow=none;strokeColor=#005862;dashed=0;" edge="1" parent="1" source="spa" target="entra">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_spa_api" value="REST + Bearer token&#10;(X-Contact-Id for company switch)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#0066b3;fontStyle=1;" edge="1" parent="1" source="spa" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_entra" value="validate JWT (JWKS)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#005862;dashed=1;" edge="1" parent="1" source="api" target="entra">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_dv" value="Dataverse Web API&#10;(Entra service principal —&#10;client credentials)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;endArrow=block;strokeColor=#6a2fb5;fontStyle=1;" edge="1" parent="1" source="api" target="dv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="Tech: React SPA. Hosting: all Microsoft Azure UK regions (UK South) — UK data residency across the SPA, the containerised API, and Dataverse.&#10;Auth: users sign in with Entra External ID; the SPA sends the access token to the API, which validates it and resolves the caller's Dataverse contact + permissions server-side. The SPA never talks to Dataverse directly — only the API does, via an Entra service principal." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=11;fontColor=#005862;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1040" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
